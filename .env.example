# Application
APP_NAME="Yii2 Blog API"
APP_ENV=dev
APP_DEBUG=true
COOKIE_VALIDATION_KEY=your-random-secret-key-here

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=yii2_blog
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Cloudflare Common Configuration
CF_ACCOUNT_ID=

# Cloudflare R2
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Cloudflare Workers AI
AI_WORKER_URL=
AI_WORKER_TOKEN=
AI_WORKER_MODEL="@cf/meta/llama-3.1-8b-instruct"
