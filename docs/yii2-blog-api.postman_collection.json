    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"reader_two\",\n    \"email\": \"reader_two@example.com\",\n    \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://yii2-app-basic.test/api/auth/register",
              "protocol": "http",
              "host": [
                "yii2-app-basic",
                "test"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Đăng ký tài khoản mới. Tự động gán role `reader`."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('token', json.data.access_token);",
                  "    console.log('Token saved:', json.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin_root\",\n    \"password\": \"admin123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://yii2-app-basic.test/api/auth/login",
              "protocol": "http",
              "host": [
                "yii2-app-basic",
                "test"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập. Token sẽ tự động lưu vào collection variable `{{token}}`."
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://yii2-app-basic.test/api/auth/me",
              "protocol": "http",
              "host": [
                "yii2-app-basic",
                "test"
